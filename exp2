
# Candidate Elimination Algorithm (Simple & Google Colab Ready)# Describes all hypotheses consistent with CSV training dataimport csvimport pandas as pdimport numpy as np# ---------- Create CSV Data ----------# Define the training data as a numpy array, then convert to DataFrame for easy CSV writing.training_data_array = np.array([    ['Sunny', 'Warm', 'Normal', 'Strong', 'Warm', 'Same', 'Yes'],    ['Sunny', 'Warm', 'High', 'Strong', 'Warm', 'Same', 'Yes'],    ['Rainy', 'Cold', 'High', 'Strong', 'Warm', 'Change', 'No'],    ['Sunny', 'Warm', 'High', 'Strong', 'Cool', 'Change', 'Yes']])df_training = pd.DataFrame(training_data_array, columns=['Sky', 'AirTemp', 'Humidity', 'Wind', 'Water', 'Forecast', 'Label'])df_training.to_csv('training_data.csv', index=False)print("Created 'training_data.csv' successfully.")# ---------- Load CSV Data ----------# CSV format:# Sky,AirTemp,Humidity,Wind,Water,Forecast,Label# Sunny,Warm,Normal,Strong,Warm,Same,Yesdef load_csv(filename):    data = []    with open(filename, 'r') as file:        reader = csv.reader(file)        next(reader)  # skip header        for row in reader:            data.append((row[:-1], row[-1]))    return data# ---------- Helper Functions ----------def more_general(h1, h2):    return all(x == "?" or x == y for x, y in zip(h1, h2))def min_generalization(h, x):    new_h = h[:]    for i in range(len(h)):        if h[i] == "Ø":            new_h[i] = x[i]        elif h[i] != x[i]:            new_h[i] = "?"    return new_hdef min_specialization(h, domains, x):    specializations = []    for i in range(len(h)):        if h[i] == "?":            for value in domains[i]:                if value != x[i]:                    new_h = h[:]                    new_h[i] = value                    specializations.append(new_h)    return specializations# ---------- Candidate Elimination ----------def candidate_elimination(data, domains):    num_attr = len(data[0][0])    S = [["Ø"] * num_attr]    G = [["?"] * num_attr]    for x, label in data:        if label == "Yes":            G = [g for g in G if more_general(g, x)]            S = [min_generalization(s, x) for s in S]            S = [s for s in S if any(more_general(g, s) for g in G)]        else:  # Negative example            S = [s for s in S if not more_general(s, x)]            new_G = []            for g in G:                if more_general(g, x):                    specs = min_specialization(g, domains, x)                    new_G.extend(specs)                else:                    new_G.append(g)            G = [g for g in new_G if any(more_general(g, s) for s in S)]    return S, G# ---------- Example Usage ----------# Define attribute domains (update according to your CSV)domains = [    ["Sunny", "Rainy"],    ["Warm", "Cold"],    ["Normal", "High"],    ["Strong", "Weak"],    ["Warm", "Cool"],    ["Same", "Change"]]# Load training datadata = load_csv("training_data.csv")# Run algorithmS_final, G_final = candidate_elimination(data, domains)# Outputprint("Final Specific Hypotheses (S):")for s in S_final:    print(s)print("\nFinal General Hypotheses (G):")for g in G_final:    print(g)
