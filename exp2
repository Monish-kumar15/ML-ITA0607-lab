
# Genetic Programming for Symbolic Regression# Simple, from-scratch, Google Colab Readyimport randomimport math# -------- Dataset (y = x^2 + x + 1) --------X = [i for i in range(-5, 6)]Y = [x**2 + x + 1 for x in X]# -------- Function & Terminal Sets --------functions = ['+', '-', '*']terminals = ['x', -2, -1, 0, 1, 2, 3]# -------- Generate Random Expression --------def random_expr(depth=3):    if depth == 0:        return random.choice(terminals)    return [        random.choice(functions),        random_expr(depth-1),        random_expr(depth-1)    ]# -------- Evaluate Expression --------def eval_expr(expr, x):    if expr == 'x':        return x    if isinstance(expr, int):        return expr    op, left, right = expr    a = eval_expr(left, x)    b = eval_expr(right, x)    if op == '+': return a + b    if op == '-': return a - b    if op == '*': return a * b    return 0 # Should not reach here# -------- Fitness (Mean Squared Error) --------def fitness(expr):    error = 0    for x_val, y_true in zip(X, Y):        try:            y_pred = eval_expr(expr, x_val)            error += (y_pred - y_true) ** 2        except (OverflowError, TypeError): # Handle potential division by zero or large numbers            error += 1000000 # Large penalty for invalid expressions    return error / len(X)# -------- Crossover --------def crossover(p1, p2):    # Simple crossover: randomly choose one parent's subtree or root    if random.random() < 0.5:        return p1    return p2# -------- Mutation --------def mutate(expr, rate=0.1):    if random.random() < rate:        return random_expr(2)    if isinstance(expr, list):        return [expr[0], mutate(expr[1]), mutate(expr[2])]    return expr# -------- Genetic Programming --------population = [random_expr() for _ in range(50)]for generation in range(50):    population.sort(key=fitness)    next_gen = population[:10]  # elitism    while len(next_gen) < 50:        p1 = random.choice(population[:20])        p2 = random.choice(population[:20])        child = crossover(p1, p2)        child = mutate(child)        next_gen.append(child)    population = next_genbest = min(population, key=fitness)# -------- Output --------print("Best Expression:", best)print("Fitness (MSE):", fitness(best))# -------- Test Prediction --------for x_val in [-3, 0, 3]:    print(f"x={x_val}, predicted={eval_expr(best, x_val)}, actual={x_val**2 + x_val + 1}")
